<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F">

    <!-- Camera Preview -->
    <TextureView
        android:id="@+id/cameraPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <com.example.mybasic.signalguard.OverlayView
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top Toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:background="#CC10101A">

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_green"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SignalGuard"
            android:textColor="#D0D0FF"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/screenOnChip"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:text="SCREEN ON"
            android:textColor="#00E676"
            android:textSize="9sp"            android:textStyle="bold"
            android:background="@drawable/chip_green"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:gravity="center"
            android:layout_marginEnd="6dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Top-Left Signal Status -->
    <LinearLayout
        android:id="@+id/signalStatusOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC000000"
        android:padding="10dp"
        android:elevation="4dp">

        <View
            android:id="@+id/signalColorBox"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/signal_box"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/signalNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IDLE"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/sampledColorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R:--- G:--- B:---"
                android:textColor="#AAAAAA"
                android:textSize="12sp"                android:fontFamily="monospace"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Control Panel -->
    <RelativeLayout
        android:id="@+id/bottomControlPanel"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_gravity="bottom"
        android:background="#CC0A0A14"
        android:padding="8dp">

        <!-- Left Side: D-Pad and Settings -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentStart="true"
            android:orientation="vertical"
            android:gravity="bottom">

            <!-- D-Pad -->
            <com.example.mybasic.signalguard.DPadView
                android:id="@+id/dpadView"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginBottom="4dp"/>

            <!-- Settings Corner Button (Square) -->
            <TextView
                android:id="@+id/btnSettingsCorner"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="⚙"
                android:textColor="#7777AA"
                android:textSize="22sp"
                android:gravity="center"
                android:background="#222233"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Center: START Button, Signal Text, and RGB -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="8dp"
            android:orientation="vertical"            android:gravity="center">

            <!-- START Button -->
            <Button
                android:id="@+id/btnStartStop"
                android:layout_width="140dp"
                android:layout_height="45dp"
                android:text="▶ START"
                android:backgroundTint="#1B5E20"
                android:textColor="#55FF88"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"/>

            <!-- Signal Name Display (RED/YELLOW/GREEN) - NOT A BUTTON -->
            <TextView
                android:id="@+id/signalAspectText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IDLE"
                android:textColor="#8888AA"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>

            <!-- RGB Values -->
            <TextView
                android:id="@+id/rgbValueText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R:--- G:--- B:---"
                android:textColor="#AAAACC"
                android:textSize="11sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <!-- Right Side: Vertical Zoom and Glass Orb -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal"
            android:gravity="bottom|end">

            <!-- Vertical Zoom Dial -->
            <com.example.mybasic.signalguard.ZoomDialView
                android:id="@+id/zoomDialView"
                android:layout_width="40dp"
                android:layout_height="140dp"                android:layout_marginEnd="8dp"/>

            <!-- Glass Orb (Visual Indicator Light - NOT A BUTTON) -->
            <View
                android:id="@+id/glassOrb"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/glass_orb"
                android:elevation="8dp"/>
        </LinearLayout>

        <!-- Zoom Label -->
        <TextView
            android:id="@+id/zoomLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_above="@id/glassOrb"
            android:layout_marginEnd="15dp"
            android:layout_marginBottom="8dp"
            android:text="1.0x"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </RelativeLayout>

    <!-- Status Bar -->
    <TextView
        android:id="@+id/watchingStatusText"
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="205dp"
        android:text="Not watching — press START to arm alarm"
        android:textColor="#44445A"
        android:textSize="10sp"
        android:gravity="center"
        android:background="#0E0E18"/>

    <!-- Settings Panel -->
    <LinearLayout
        android:id="@+id/settingsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#0A0A14"
        android:padding="16dp"        android:visibility="gone"
        android:elevation="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DISPLAY SETTINGS"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Keep screen on"
                android:textColor="#BBBBDD"
                android:textSize="12sp"/>
            <Switch
                android:id="@+id/switchKeepScreenOn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Allow dimming"
                android:textColor="#9999BB"
                android:textSize="12sp"/>
            <Switch
                android:id="@+id/switchAllowDimming"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"/>
        </LinearLayout>
    </LinearLayout>
    <!-- Hidden Views -->
    <TextView
        android:id="@+id/signalDescText"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>
    <View
        android:id="@+id/sampledColorSwatch"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>

</FrameLayout>